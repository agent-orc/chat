{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "coding-agent-chat": {
      "projectType": "library",
      "root": "projects/coding-agent-chat",
      "sourceRoot": "projects/coding-agent-chat",
      "prefix": "cac",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/coding-agent-chat/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/coding-agent-chat/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/coding-agent-chat/tsconfig.spec.json"
          }
        }
      }
    },
    "conversation-lab": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/conversation-lab",
      "sourceRoot": "projects/conversation-lab/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/conversation-lab/src/main.ts",
            "tsConfig": "projects/conversation-lab/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/conversation-lab/public"
              }
            ],
            "styles": [
              "projects/conversation-lab/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "600kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10kB",
                  "maximumError": "16kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "live": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "tsConfig": "projects/conversation-lab/tsconfig.live.json",
              "styles": [
                "projects/conversation-lab/src/styles-live.scss"
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4201,
            "prebundle": {
              "exclude": [
                "@coding-agent/chat",
                "@coding-agent/chat/core",
                "@coding-agent/chat/shared",
                "@coding-agent/chat/markdown",
                "@coding-agent/chat/conversation",
                "@coding-agent/chat/composer",
                "@coding-agent/chat/history"
              ]
            }
          },
          "configurations": {
            "production": {
              "buildTarget": "conversation-lab:build:production"
            },
            "development": {
              "buildTarget": "conversation-lab:build:development"
            },
            "live": {
              "buildTarget": "conversation-lab:build:live"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "website": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/website",
      "sourceRoot": "projects/website/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/website/src/main.ts",
            "server": "projects/website/src/main.server.ts",
            "outputMode": "static",
            "tsConfig": "projects/website/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/website/public"
              }
            ],
            "styles": [
              "projects/website/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "900kB",
                  "maximumError": "1.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "live": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "tsConfig": "projects/website/tsconfig.live.json",
              "styles": [
                "projects/website/src/styles-live.scss"
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4202,
            "prebundle": {
              "exclude": [
                "@coding-agent/chat",
                "@coding-agent/chat/core",
                "@coding-agent/chat/shared",
                "@coding-agent/chat/markdown",
                "@coding-agent/chat/conversation",
                "@coding-agent/chat/composer",
                "@coding-agent/chat/history"
              ]
            }
          },
          "configurations": {
            "production": {
              "buildTarget": "website:build:production"
            },
            "development": {
              "buildTarget": "website:build:development"
            },
            "live": {
              "buildTarget": "website:build:live"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
