{
  "name": "coding-agent-chat",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "ng build coding-agent-chat",
    "watch": "ng build coding-agent-chat --watch --configuration development",
    "pack": "npm pack ./dist/coding-agent-chat --pack-destination ./dist",
    "lab": "ng serve conversation-lab",
    "lab:live": "ng serve conversation-lab --configuration live",
    "workbench": "dotnet run --project workbench",
    "website": "ng serve website",
    "release:stamp": "node scripts/stamp-release.mjs",
    "release:verify": "node scripts/verify-release.mjs",
    "benchmark:history": "npm run build && node scripts/benchmark-history-window.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "website:live": "ng serve website --configuration live"
  },
  "private": true,
  "packageManager": "npm@11.3.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "~21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "~21.2.0",
    "dompurify": "^3.4.2",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "marked": "^18.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.17",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/localize": "^21.2.17",
    "@types/node": "^24.0.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
